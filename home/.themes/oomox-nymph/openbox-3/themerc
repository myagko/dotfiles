# Menu
menu.border.color: #BCC4C9

menu.title.bg: Solid Flat
menu.title.bg.color: #1A2023
menu.title.bg.shadow: 0
menu.title.text.color: #BCC4C9
menu.title.text.justify: Center

menu.items.bg: Solid Flat
menu.items.bg.color: #1A2023
menu.items.text.color: #BCC4C9
menu.items.disabled.text.color: #939b9f

menu.items.active.bg: Solid Flat
menu.items.active.bg.color: #89B7B0
menu.items.active.text.color: #BCC4C9

menu.separator.color: #939b9f
menu.separator.width: 1
menu.separator.padding.width: 2
menu.separator.padding.height: 4

# Window focused
window.active.title.separator.color: #1A2023

# Active window
window.active.border.color: #373D40


window.active.title.bg: flat solid
window.active.title.bg.color: #1A2023
window.active.title.separator.color: #1A2023
window.active.text.justify: center

window.active.label.bg: parentrelative
window.active.label.text.color: #BCC4C9

window.active.handle.bg: flat solid
window.active.handle.bg.color: #1A2023

window.active.grip.bg: flat solid
window.active.grip.bg.color: #1A2023

window.active.button.unpressed.bg: flat solid
window.active.button.unpressed.bg.color: #1A2023
window.active.button.unpressed.image.color: #BCC4C9

window.active.button.pressed.bg: flat solid
window.active.button.pressed.bg.color: #89B7B0
window.active.button.pressed.image.color: #1A2023

window.active.button.disabled.bg: flat solid
window.active.button.disabled.bg.color: #1A2023
window.active.button.disabled.image.color: #939b9f

window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: #1A2023
window.active.button.hover.image.color: #89B7B0

#window.active.button.toggled.bg: #89B7B0
#window.active.button.toggled.image.color: #1A2023

# Inactive window
window.inactive.border.color: #373D40

window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #1A2023
window.inactive.title.separator.color: #1A2023
window.inactive.text.justify: center

window.inactive.label.bg: parentrelative
window.inactive.label.text.color: #939b9f

window.inactive.handle.bg: flat solid
window.inactive.handle.bg.color: #1A2023

window.inactive.grip.bg: flat solid
window.inactive.grip.bg.color: #1A2023

window.inactive.button.unpressed.bg: flat solid
window.inactive.button.unpressed.bg.color: #1A2023
window.inactive.button.unpressed.image.color: #939b9f

window.inactive.button.pressed.bg: flat solid
window.inactive.button.pressed.bg.color: #89B7B0
window.inactive.button.pressed.image.color: #1A2023

window.inactive.button.disabled.bg: flat solid
window.inactive.button.disabled.bg.color: #939b9f
window.inactive.button.disabled.image.color: #1A2023

window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: #1A2023
window.inactive.button.hover.image.color: #89B7B0


# OSD
osd.border.width: 1
osd.border.color: #89B7B0

osd.bg: flat solid
osd.bg.color: #1A2023
osd.label.bg: flat solid
osd.label.bg.color: #1A2023
osd.label.text.color: #BCC4C9

# OSD
osd.bg: Solid Flat
osd.bg.color: #1A2023
osd.bg.shadow: 0

osd.border.width: 2
osd.hilight.bg: Solid Flat
osd.hilight.bg.color: #89B7B0
osd.unhilight.bg: flat solid
osd.unhilight.bg.color: #1A2023

osd.button.unpressed.bg: flat border
osd.button.unpressed.bg.color: #252B2E
#osd.button.unpressed.*.border.color: #BCC4C9

osd.button.pressed.bg: flat border
osd.button.pressed.bg.color: #89B7B0
#osd.button.pressed.*.border.color: #1A2023

osd.button.focused.bg: flat solid border
osd.button.focused.bg.color: #BCC4C9
#osd.button.focused.*.border.color: #1A2023

osd.button.focused.box.color: #89B7B0


# Fonts
window.active.label.text.font:shadow=n
window.inactive.label.text.font:shadow=n
menu.items.font:shadow=n
menu.title.text.font:shadow=n


# Everything else
border.width: 5
padding.width: 8
padding.height: 5
window.handle.width: 0
window.client.padding.width: 0
window.label.text.justify: center
#menu.overlap: 0
